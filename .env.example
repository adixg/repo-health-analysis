# ---------------------------------------------------------------------------
# GitHub API (required for ingestion)
# Create a token at: https://github.com/settings/tokens
# Scopes needed: public_repo (or repo if you will ingest private repos)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_token_here

# Optional: override the GitHub API base URL (defaults to https://api.github.com)
# GITHUB_API_BASE_URL=https://api.github.com

# ---------------------------------------------------------------------------
# PostgreSQL (required for storage)
# Defaults match docker-compose.yml — copy this file to .env and adjust.
# ---------------------------------------------------------------------------
POSTGRES_USER=reposense
POSTGRES_PASSWORD=reposense
POSTGRES_DB=reposense
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full SQLAlchemy URL (auto-built from the vars above if left blank)
# DATABASE_URL=postgresql+psycopg2://reposense:reposense@localhost:5432/reposense

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# Local cache for GitHub API responses (rate-limit mitigation)
CACHE_DIR=data/cache

# Optional cap on issue pages per repo (100 issues/page). Leave blank for no limit.
# ISSUES_MAX_PAGES=10

# Days before an open issue is considered stale
STALE_ISSUE_DAYS=90

# Sample repos to ingest during development (comma-separated owner/repo)
#
# Recommended phased list for Python ML/data-science analysis:
#   Phase 1 (dev):     octocat/Hello-World, fastai/fastai, explosion/spaCy, psf/requests
#   Phase 2 (eval):    scikit-learn/scikit-learn, huggingface/datasets
#   Phase 3 (flagship): pandas-dev/pandas, pytorch/pytorch, tensorflow/tensorflow
SAMPLE_REPOS=octocat/Hello-World,fastai/fastai,explosion/spaCy,psf/requests
